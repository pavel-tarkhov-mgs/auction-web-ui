# Auction gRPC service address (default port when running locally)
AUCTION_GRPC_HOST=localhost:5001

# Inventory gRPC service address
# NOTE: both services default to 5001; run inventory with a different port in dev
# e.g.  dotnet run --Kestrel:GrpcPort=5002
INVENTORY_GRPC_HOST=localhost:30006

# Currency template id used by the +100 button in UI
CURRENCY_TEMPLATE_ID=currency_coupons

# Web server port
PORT=3000
